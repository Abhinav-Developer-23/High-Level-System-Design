## Code Implementation Guidelines

### When Writing Comment Service Code

```typescript
// ✅ CORRECT: Non-blocking, immediate response
async function postComment(streamId, userId, text) {
  // 1. Validate
  validateComment(text, userId);
  
  // 2. Create comment object
  const comment = {
    comment_id: generateUUID(),
    stream_id: streamId,
    user_id: userId,
    timestamp: Date.now(), // Server-side timestamp!
    text: text
  };
  
  // 3. Parallel operations (don't await both!)
  Promise.all([
    redis.publish(`comments:${streamId}`, comment),
    db.insert('comments', comment) // async, fire-and-forget
  ]).catch(err => logger.error('Comment processing failed', err));
  
  // 4. Return immediately
  return { status: 202, body: { comment_id: comment.comment_id } };
}

// ❌ WRONG: Blocking on database
async function postComment(streamId, userId, text) {
  const comment = createComment(streamId, userId, text);
  await db.insert('comments', comment); // Don't wait!
  await redis.publish(`comments:${streamId}`, comment);
  return { status: 200, body: comment };
}
```

### When Writing Connection Gateway Code

```typescript
// ✅ CORRECT: Dynamic subscription with batching
class SSEGateway {
  private connections = new Map<string, Set<SSEConnection>>();
  private subscriptions = new Map<string, RedisSubscription>();
  private batchBuffer = new Map<string, Comment[]>();
  
  async subscribe(streamId: string, connection: SSEConnection) {
    // Add connection to stream
    if (!this.connections.has(streamId)) {
      this.connections.set(streamId, new Set());
      // First viewer - subscribe to Redis topic
      await this.subscribeToStream(streamId);
    }
    this.connections.get(streamId).add(connection);
    
    // Handle disconnect
    connection.on('close', () => this.unsubscribe(streamId, connection));
  }
  
  private async subscribeToStream(streamId: string) {
    const sub = await redis.subscribe(`comments:${streamId}`);
    sub.on('message', (comment) => this.bufferComment(streamId, comment));
    this.subscriptions.set(streamId, sub);
  }
  
  private bufferComment(streamId: string, comment: Comment) {
    if (!this.batchBuffer.has(streamId)) {
      this.batchBuffer.set(streamId, []);
      // Schedule flush after 100ms
      setTimeout(() => this.flushBatch(streamId), 100);
    }
    this.batchBuffer.get(streamId).push(comment);
  }
  
  private flushBatch(streamId: string) {
    const batch = this.batchBuffer.get(streamId);
    if (!batch || batch.length === 0) return;
    
    const connections = this.connections.get(streamId);
    const payload = `data: ${JSON.stringify(batch)}\n\n`;
    
    connections.forEach(conn => conn.write(payload));
    this.batchBuffer.delete(streamId);
  }
}
```

### When Writing Playback Client Code

```javascript
// ✅ CORRECT: Chunked loading with synchronization
class CommentPlayback {
  constructor(streamId, videoPlayer) {
    this.streamId = streamId;
    this.player = videoPlayer;
    this.buffer = [];
    this.currentChunkEnd = 0;
  }
  
  async start() {
    // Load initial chunk (0-3 minutes)
    await this.loadChunk(0, 180);
    
    // Sync with video player
    this.player.on('timeupdate', () => this.renderComments());
    this.player.on('seek', (time) => this.handleSeek(time));
  }
  
  async loadChunk(startTime, duration) {
    const response = await fetch(
      `/v1/streams/${this.streamId}/comments?start_time=${startTime}&duration=${duration}`
    );
    const data = await response.json();
    this.buffer.push(...data.comments);
    this.currentChunkEnd = data.next_start_time;
  }
  
  renderComments() {
    const currentTime = this.player.currentTime;
    
    // Render comments that should appear now
    while (this.buffer.length > 0 && this.buffer[0].timestamp <= currentTime) {
      const comment = this.buffer.shift();
      this.displayComment(comment);
    }
    
    // Proactive buffering (at 80% of current chunk)
    if (currentTime >= this.currentChunkEnd * 0.8) {
      this.loadChunk(this.currentChunkEnd, 180);
    }
  }
  
  async handleSeek(targetTime) {
    // Discard current buffer
    this.buffer = [];
    
    // Load chunk for new timestamp
    const chunkStart = Math.floor(targetTime / 180) * 180;
    await this.loadChunk(chunkStart, 180);
  }
}
```

### When Designing Database Queries

```sql
-- ✅ CORRECT: Uses partition key and clustering key
SELECT * FROM comments 
WHERE stream_id = 'abc-123' 
  AND timestamp >= '2025-10-18T12:00:00'
  AND timestamp <= '2025-10-18T12:03:00'
LIMIT 100;

-- ❌ WRONG: Missing partition key (full table scan!)
SELECT * FROM comments 
WHERE user_id = 'user-456'
LIMIT 100;

-- ✅ CORRECT: Denormalized data (no joins needed)
-- Store username with comment to avoid lookup
INSERT INTO comments (stream_id, timestamp, comment_id, user_id, username, comment_text)
VALUES (?, ?, ?, ?, ?, ?);

-- ❌ WRONG: Normalized design requiring joins
-- Don't do this in NoSQL:
-- SELECT c.*, u.username FROM comments c JOIN users u ON c.user_id = u.id
```

